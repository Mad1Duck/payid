# =========================
# NETWORK CONFIG
# =========================
# 0G Galileo Testnet (16602) | 0G Newton Fork (16601) | 0G Newton (16600)
VITE_CHAIN_ID=16602

# =========================
# PINATA CONFIG (Legacy IPFS)
# =========================
# Get your JWT at https://app.pinata.cloud/developers/api-keys
VITE_PINATA_JWT=
# Optional: your dedicated Pinata gateway
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud

# =========================
# 0G STORAGE CONFIG
# =========================
# Turbo indexer — recommended for 0G Galileo Testnet
VITE_0G_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
# EVM RPC for 0G Galileo Testnet
VITE_0G_STORAGE_RPC=https://evmrpc-testnet.0g.ai
# HTTP gateway for reading stored files
VITE_0G_STORAGE_GATEWAY=https://indexer-storage-testnet-turbo.0g.ai
# (alias used by zgStorage.ts)
VITE_ZGS_RPC_URL=https://evmrpc-testnet.0g.ai
VITE_ZGS_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
VITE_ZGS_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# =========================
# 0G AI COMPUTE CONFIG
# =========================
# Get your API key at https://pc.0g.ai (connect wallet → API Keys)
VITE_0G_AI_API_KEY=
# 0G AI inference endpoint (OpenAI-compatible, via 0G Compute Network)
VITE_0G_AI_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy
# Model — see available models at https://hub.0g.ai
VITE_0G_AI_MODEL=qwen/qwen-2.5-7b-instruct
