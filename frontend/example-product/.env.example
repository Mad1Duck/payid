# Pinata — required for auto IPFS upload in Rule Builder
# Get your JWT at https://app.pinata.cloud/developers/api-keys
VITE_PINATA_JWT=

# Optional: your dedicated Pinata gateway (default: https://gateway.pinata.cloud)
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud

# 0G Storage — used automatically when connected to 0G Newton Testnet (chain 16601)
# Turbo indexer is recommended for testnet
VITE_0G_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
# EVM RPC used by the 0G SDK to submit the storage transaction
VITE_0G_STORAGE_RPC=http://100.73.196.95:8550
# HTTP gateway for reading stored files (storage-node HTTP API)
# Format: <gateway-url>/file?root=<rootHash>
VITE_0G_STORAGE_GATEWAY=https://indexer-storage-testnet-turbo.0g.ai
