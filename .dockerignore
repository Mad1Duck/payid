# ═══════════════════════════════════════════════════════════════
# Root .dockerignore — applies when building from monorepo root
# ═══════════════════════════════════════════════════════════════

# Git
.git/
.gitignore

# Node modules (installed in container)
**/node_modules/

# Build outputs
**/dist/
!packages/*/dist/
!frontend/*/dist/
**/*.tsbuildinfo

# Docker files (not needed inside container)
**/Dockerfile
**/docker-compose.yml
**/.dockerignore

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log

# Testing
coverage/
**/*.test.ts
**/*.test.tsx

# Documentation site (not needed for example-product build)
docs/

# Examples (not needed for build)
examples/

# Frontend docs build output
frontend/frontend-docs/build/
frontend/frontend-docs/node_modules/

# Contract artifacts (built in container if needed)
packages/contracts/artifacts/
packages/contracts/cache/
packages/contracts/typechain/
packages/contracts/ignition/deployments/

# Package manager caches
.pnpm-store/
