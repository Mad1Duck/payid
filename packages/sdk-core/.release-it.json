{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "npm": {
    "publish": true,
    "publishPath": "."
  },
  "git": {
    "commitMessage": "chore: release payid@${version}",
    "tagName": "payid@${version}",
    "requireCleanWorkingDir": false,
    "commit": true,
    "tag": true,
    "push": true
  },
  "hooks": {
    "before:bump": "bun run type-check",
    "after:bump": "bun run build"
  },
  "plugins": {}
}
