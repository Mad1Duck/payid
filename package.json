{
  "module": "index.ts",
  "name": "programmable-payment-policy",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "frontend/*"
  ],
  "scripts": {
    "build": "bun run --filter ./packages/* build",
    "sync": "bun run --cwd packages/contracts sync",
    "sync:local": "bun run --cwd packages/contracts sync:local",
    "dev:example": "bun run --cwd frontend/example-product dev",
    "client": "bun run examples/simple/client.ts",
    "server": "bun run examples/simple/server.ts",
    "setup:upload": "bun run examples/simple/rule.nft/upload-rule-nft-to-pinata.ts",
    "setup:create-rule": "bun run examples/simple/rule.nft/create-rule-item.ts",
    "setup:register": "bun run examples/simple/combiner.rule/register-combined-rule.ts",
    "setup:debug": "bun run examples/simple/payment.ts",
    "fix:whitelist": "bun run examples/simple/whitelist-authority.ts",
    "fix:expiry": "bun run examples/simple/fix-rule-expiry.ts",
    "fix:usdc": "bun run examples/simple/mint-usdc.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lerna": "^9.0.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "pinata": "^2.5.2"
  },
  "overrides": {
    "viem": "^2.46.3",
    "wagmi": "^3.5.0",
    "@wagmi/core": "^3.0.0"
  },
  "packageManager": "pnpm@10.4.0+sha512.6b849d0787d97f8f4e1f03a9b8ff8f038e79e153d6f11ae539ae7c435ff9e796df6a862c991502695c7f9e8fac8aeafc1ac5a8dab47e36148d183832d886dd52"
}
